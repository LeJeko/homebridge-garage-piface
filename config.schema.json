{
    "pluginAlias": "GaragePiFace",
    "pluginType": "platform",
    "singular": true,
    "headerDisplay": "Plugin for garage door / gate control using a Raspberry Pi with PiFace Digital board.",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Platform name",
                "type": "string",
                "default": "Garage PiFace"
            },
            "accessories": {
                "title": "Garage Doors / Gates",
                "type": "array",
                "items": {
                    "title": "Garage Door",
                    "type": "object",
                    "properties": {
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": true
                        },
                        "switchOutput": {
                            "title": "Switch Output",
                            "type": "integer",
                            "default": 0,
                            "required": true,
                            "description": "PIface output relay to trigger (0–7)."
                        },
                        "switchValue": {
                            "title": "Switch Output Value",
                            "type": "integer",
                            "default": 1,
                            "required": false,
                            "description": "Output value to activate relay (1 = ACTIVE_HIGH, 0 = ACTIVE_LOW)."
                        },
                        "switchPressTimeInMs": {
                            "title": "Switch Press Time (ms)",
                            "type": "number",
                            "default": 1000,
                            "required": false,
                            "description": "Duration to keep the relay activated."
                        },
                        "closedSensorInput": {
                            "title": "Closed Sensor Input",
                            "type": "integer",
                            "required": false,
                            "description": "PIface input pin to detect closed position (0–7). Leave empty if not used."
                        },
                        "closedSensorValue": {
                            "title": "Closed Sensor Value",
                            "type": "integer",
                            "default": 1,
                            "required": false,
                            "description": "Input value when door is closed."
                        },
                        "openSensorInput": {
                            "title": "Open Sensor Input",
                            "type": "integer",
                            "required": false,
                            "description": "PIface input pin to detect open position (0–7). Leave empty if not used."
                        },
                        "openSensorValue": {
                            "title": "Open Sensor Value",
                            "type": "integer",
                            "default": 1,
                            "required": false,
                            "description": "Input value when door is open."
                        },
                        "pollInMs": {
                            "title": "Poll Interval (ms)",
                            "type": "number",
                            "default": 4000,
                            "required": false,
                            "description": "How often to poll sensor state."
                        },
                        "opensInSeconds": {
                            "title": "Open/Close Duration (s)",
                            "type": "number",
                            "default": 10,
                            "required": false,
                            "description": "Time in seconds for the door to fully open or close."
                        }
                    }
                }
            }
        }
    }
}
